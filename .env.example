SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=fr

# Database - PostgreSQL for production (free tier options below)
# Leave empty to use SQLite for local development without PostgreSQL installed
# 
# Free PostgreSQL providers:
#   Supabase:        postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#   Neon:            postgresql://[USER]:[PASSWORD]@ep-[LOCATION]-[ID].pool.dev:5432/[DATABASE]
#   Railway:         postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
#   Local fallback:  (leave DATABASE_URL empty or unset to use SQLite)
DATABASE_URL=

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@plagenor.dz

# Platform settings
IBTIKAR_BUDGET_CAP=200000
VAT_RATE=0.19
INVOICE_PREFIX=GENOCLAB-INV

# Static & media
STATIC_ROOT=staticfiles
MEDIA_ROOT=media
