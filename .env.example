# =============================================================================
# PLAGENOR 4.0 - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# 🔴 CRITICAL SECURITY SETTINGS (MUST CONFIGURE FOR PRODUCTION)
# =============================================================================

# Generate a new SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-random-50-char-string

# DEBUG=False is REQUIRED for production
DEBUG=False

# Add your production domain(s) - comma-separated
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# =============================================================================
# 🟡 IMPORTANT SECURITY SETTINGS
# =============================================================================

# Enable secure cookies (HTTPS required)
# SECURE_SSL_REDIRECT=True

# CSRF cookie security
CSRF_COOKIE_SECURE=True
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Session security
SESSION_COOKIE_SECURE=True

# =============================================================================
# 🗄️ DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL is recommended for production (>10 concurrent users)
# Leave empty to use SQLite for local development only

# Free PostgreSQL providers:
#   Railway:      postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]
#   Supabase:     postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#   Neon:         postgresql://[USER]:[PASSWORD]@ep-[LOCATION]-[ID].pool.dev:5432/[DATABASE]
#   Render:       postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]

DATABASE_URL=

# =============================================================================
# 📧 EMAIL / SMTP CONFIGURATION
# =============================================================================
# Configure for production email delivery

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# Alternative: Use environment-specific defaults
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# =============================================================================
# 🔍 ERROR TRACKING - SENTRY
# =============================================================================
# Sign up at https://sentry.io and create a DSN
# SENTRY_DSN=https://[key]@[org].sentry.io/[project]

# =============================================================================
# ⚡ CACHING - REDIS (Optional but recommended)
# =============================================================================
# Redis URL for caching and session storage
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 📦 PLATFORM SETTINGS
# =============================================================================
LANGUAGE_CODE=fr

IBTIKAR_BUDGET_CAP=200000
VAT_RATE=0.19
INVOICE_PREFIX=GENOCLAB-INV

# =============================================================================
# 📁 STATIC & MEDIA FILES
# =============================================================================
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# For cloud storage (S3, Cloudflare R2, etc.):
# See: https://django-storages.readthedocs.io/en/latest/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=  # For Cloudflare R2

# =============================================================================
# 🚀 DEPLOYMENT SPECIFIC
# =============================================================================
RELEASE_VERSION=4.0.0

# Rate limiting (enabled by default)
# RATE_LIMIT_ENABLED=True

# =============================================================================
# 🛡️ RATE LIMITING SETTINGS
# =============================================================================
# Default: 100 requests per minute
# Auth endpoints: 10 requests per minute
# API endpoints: 60 requests per minute
# Upload endpoints: 20 requests per minute
